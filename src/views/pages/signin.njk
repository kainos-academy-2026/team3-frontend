{% extends "layouts/main.njk" %}

{% block title %}Kainos Careers | Sign In{% endblock %}

{% block content %}
  <section class="hero" aria-labelledby="signin-heading">
    <div class="hero__content" style="max-width: 520px;">
      <p class="hero__eyebrow">Secure Access</p>
      <h1 id="signin-heading" class="home-heading">Sign in</h1>

      {% if error %}
        <p style="color:#b42318; font-weight:700;">{{ error }}</p>
      {% endif %}

      {% if success %}
        <div style="background:#ecfdf3; border:1px solid #6ce9a6; color:#027a48; padding:1rem; border-radius:12px; margin-top:1rem;">
          <p style="margin:0 0 0.75rem 0; font-weight:700;">{{ success }}</p>
          <button type="button" class="btn-primary" onclick="window.location.href='/login'">Continue to sign in</button>
        </div>
      {% endif %}

      <form action="/login" method="post" style="display:grid; gap:1rem; margin-top:1rem;">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" />

        <button type="submit" class="btn-primary">Sign in</button>
      </form>

      <p style="margin-top:1rem;">
        New here?
        <a href="/register" style="text-decoration: underline;">Create an account</a>
      </p>
    </div>
  </section>
{% endblock %}