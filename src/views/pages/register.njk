{% extends "layouts/main.njk" %}

{% block title %}Kainos Careers | Register{% endblock %}

{% block content %}
  <section class="hero" aria-labelledby="register-heading">
    <div class="hero__content" style="max-width: 560px;">
      <p class="hero__eyebrow">Create Account</p>
      <h1 id="register-heading" class="home-heading">Register</h1>

      {% if error %}
        <p style="color:#b42318; font-weight:700;">{{ error }}</p>
      {% endif %}

      <form action="/register" method="post" style="display:grid; gap:1rem; margin-top:1rem;">
        <label for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          value="{{ formValues.email }}"
        />
        {% if fieldErrors.email %}
          <p style="color:#b42318; margin:0;">{{ fieldErrors.email }}</p>
        {% endif %}

        <label for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="new-password"
        />
        {% if fieldErrors.password %}
          <p style="color:#b42318; margin:0;">{{ fieldErrors.password }}</p>
        {% endif %}

        <label for="confirmPassword">Confirm Password</label>
        <input
          id="confirmPassword"
          name="confirmPassword"
          type="password"
          required
          autocomplete="new-password"
        />
        {% if fieldErrors.confirmPassword %}
          <p style="color:#b42318; margin:0;">{{ fieldErrors.confirmPassword }}</p>
        {% endif %}

        <button type="submit" class="btn-primary">Create account</button>
      </form>

      <p style="margin-top:1rem;">
        Already have an account?
        <a href="/login" style="text-decoration: underline;">Sign in</a>
      </p>
    </div>
  </section>
{% endblock %}