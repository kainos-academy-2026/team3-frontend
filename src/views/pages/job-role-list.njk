{% extends "layouts/main.njk" %}

{% block title %}Kainos Careers | Open Job Roles{% endblock %}

{% block content %}
  <section class="roles-section" aria-labelledby="roles-list-heading">
    <div class="roles-section__header">
      <h1 id="roles-list-heading">Current opportunities</h1>
      {% if isAdmin %}
        <a class="button roles-section__create-button" href="/job-roles/new">Create new role</a>
      {% endif %}
    </div>

    {% if roleDeleted %}
      <p class="form-success" role="status">Role deleted successfully.</p>
    {% endif %}

    {% if deleteError == "has-applications" %}
      <p class="form-error" role="alert">This role cannot be deleted because it already has applications.</p>
    {% elif deleteError %}
      <p class="form-error" role="alert">Unable to delete this role. Please try again.</p>
    {% endif %}

    {% if created %}
      <div class="roles-section__success-banner" role="status" aria-live="polite">
        Job role created successfully.
      </div>
    {% endif %}

    {% if errorMessage %}
      <div class="empty-state" role="alert" aria-live="polite">
        <h2>{{ errorTitle or "Unable to load job roles" }}</h2>
        <p>{{ errorMessage }}</p>
      </div>
    {% elif jobRoles and jobRoles.length > 0 %}
      <div class="roles-grid">
        {% for role in jobRoles %}
          <div class="role-card-wrapper">
            <a href="/job-roles/{{ role.id }}" aria-label="View {{ role.roleName }} role details">
              <article class="role-card" aria-label="{{ role.roleName }} role">
                <div class="role-card__header">
                  <p class="role-card__capability">{{ role.capability.capabilityName }}</p>
                  <h2>{{ role.roleName }}</h2>
                </div>

                <dl class="role-card__details">
                  <div>
                    <dt>Location</dt>
                    <dd>{{ role.location }}</dd>
                  </div>
                  <div>
                    <dt>Band</dt>
                    <dd>{{ role.band.bandName }}</dd>
                  </div>
                  <div>
                    <dt>Closing date</dt>
                    <dd>{{ role.closingDate }}</dd>
                  </div>
                </dl>
              </article>
            </a>
            {% if isAdmin %}
              <form class="role-card-delete" action="/job-roles/{{ role.id }}/delete" method="post" onsubmit="return confirm('Delete this role permanently? This action cannot be undone.');">
                <button type="submit" class="btn-danger btn-small">Delete role</button>
              </form>
            {% endif %}
          </div>
        {% endfor %}
      </div>
      {% if isAdmin %}
        <div class="roles-report-action">
          <a class="btn-primary" href="/job-roles/report">Generate CSV report</a>
        </div>
      {% endif %}
    {% else %}
      <div class="empty-state">
        <h2>No open job roles found.</h2>
        <p>Please check back soon for new Kainos opportunities.</p>
      </div>
    {% endif %}
  </section>
{% endblock %}