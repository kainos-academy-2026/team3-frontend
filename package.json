{
	"name": "team3-frontend",
	"version": "1.0.0",
	"description": "Our Team Project Frontend",
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:bdd": "TS_NODE_PROJECT=tsconfig.bdd.json cucumber-js --loader ts-node/esm --import bods/fixtures/bods.fixture.ts --import bods/steps/**/*.ts bods/features/**/*.feature",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"format": "biome format --write .",
		"lint": "biome check .",
		"lint:fix": "biome check --write",
		"lint:ci": "biome ci .",
		"test:bdd": "cucumber-js --require tests/bods/fixtures/**/*.cjs --require tests/bods/steps/**/*.cjs tests/bods/features/**/*.feature",
		"test:bdd:smoke": "cucumber-js --require tests/bods/fixtures/**/*.cjs --require tests/bods/steps/**/*.cjs --tags @smoke tests/bods/features/**/*.feature"
	},
	"vitest": {
		"environment": "node"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kainos-academy-2026/team3-frontend.git"
	},
	"author": "The Full-Stack Four",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/kainos-academy-2026/team3-frontend/issues"
	},
	"homepage": "https://github.com/kainos-academy-2026/team3-frontend#readme",
	"dependencies": {
		"axios": "^1.18.1",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-session": "^1.19.0",
		"nunjucks": "^3.2.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@cucumber/cucumber": "^13.2.0",
		"@playwright/test": "^1.61.1",
		"@types/axios": "^0.9.36",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.19.0",
		"@types/node": "^26.1.0",
		"@types/nunjucks": "^3.2.6",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"supertest": "^7.2.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
